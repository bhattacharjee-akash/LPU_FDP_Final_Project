# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if platform is not identical, the lock file will prevent install;
#   alternative is to ignore Pipfile.lock and use pipenv install --skip-lock.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally recommended to be committed
.pdm.toml
.pdm-plugins/

# PEP 582; project local packages directory (used by pdm)
